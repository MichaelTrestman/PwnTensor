# PwnTensor Subnet Configuration
# Copy this file to .env and update the values

# Network Configuration
NETWORK=finney          # finney (mainnet), test (testnet), or local
NETUID=1                # Your subnet's netuid

# Validator Wallet
WALLET_NAME=default     # Validator coldkey name
HOTKEY_NAME=default     # Validator hotkey name

# Miner Wallet (separate keys from validator)
MINER_WALLET_NAME=miner
MINER_HOTKEY_NAME=default

# Miner Axon
AXON_PORT=8091          # Port miners expose for validator queries

# Logging
LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR

# Frontend
FRONTEND_PORT=8080      # Port for the game web UIs
